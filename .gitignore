cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/

# Models (DON'T commit large .pkl files to Git)
*.pkl
*.joblib

# Environment
.env
.env.local

# IDEs
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Node (frontend)
node_modules/
.next/
dist/

# C#
bin/
obj/
*.user
*.suo
EOF